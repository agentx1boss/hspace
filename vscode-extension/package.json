{
  "name": "hspace",
  "displayName": "HSpace",
  "description": "Ship your AI-built demo to exactly the right people — link + password, view receipts, revoke anytime. 稿出即递,点开即读,心里有数。",
  "version": "0.7.0",
  "publisher": "agentx1boss",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentx1boss/hspace"
  },
  "bugs": {
    "url": "https://github.com/agentx1boss/hspace/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "html",
    "markdown",
    "share",
    "publish",
    "private",
    "ai"
  ],
  "galleryBanner": {
    "color": "#1A1D24",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hspace.publish",
        "title": "HSpace: Publish current file",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "hspace.publishFolder",
        "title": "HSpace: Publish as collection"
      },
      {
        "command": "hspace.signIn",
        "title": "HSpace: Sign in with GitHub"
      },
      {
        "command": "hspace.setApiKey",
        "title": "HSpace: Set API key (paste manually)"
      },
      {
        "command": "hspace.signOut",
        "title": "HSpace: Sign out (clear API key)"
      },
      {
        "command": "hspace.setPassword",
        "title": "HSpace: Set / change password"
      },
      {
        "command": "hspace.manageGrants",
        "title": "HSpace: Manage recipients (per-recipient links)",
        "icon": "$(organization)"
      },
      {
        "command": "hspace.updateContent",
        "title": "HSpace: Update content (new version)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "hspace.versions",
        "title": "HSpace: Version history / roll back",
        "icon": "$(history)"
      },
      {
        "command": "hspace.renew",
        "title": "HSpace: Renew (extend expiry)",
        "icon": "$(clock)"
      },
      {
        "command": "hspace.copyLink",
        "title": "HSpace: Copy link"
      },
      {
        "command": "hspace.openInBrowser",
        "title": "HSpace: Open in browser"
      },
      {
        "command": "hspace.delete",
        "title": "HSpace: Delete page",
        "icon": "$(trash)"
      },
      {
        "command": "hspace.refresh",
        "title": "HSpace: Refresh list",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "hspace.publish",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "hspace.publish",
          "when": "resourceExtname == .html || resourceExtname == .htm || resourceExtname == .md || resourceExtname == .markdown",
          "group": "7_modification"
        },
        {
          "command": "hspace.publishFolder",
          "when": "explorerResourceIsFolder || resourceExtname == .html || resourceExtname == .htm || resourceExtname == .md || resourceExtname == .markdown",
          "group": "7_modification"
        }
      ],
      "view/title": [
        {
          "command": "hspace.refresh",
          "when": "view == hspace.recent",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hspace.openInBrowser",
          "when": "view == hspace.recent",
          "group": "inline"
        },
        {
          "command": "hspace.manageGrants",
          "when": "view == hspace.recent && viewItem == hspacePage",
          "group": "inline"
        },
        {
          "command": "hspace.copyLink",
          "when": "view == hspace.recent",
          "group": "1_actions"
        },
        {
          "command": "hspace.manageGrants",
          "when": "view == hspace.recent && viewItem == hspacePage",
          "group": "1_actions"
        },
        {
          "command": "hspace.updateContent",
          "when": "view == hspace.recent && viewItem == hspacePage",
          "group": "1_actions"
        },
        {
          "command": "hspace.versions",
          "when": "view == hspace.recent && viewItem == hspacePage",
          "group": "1_actions"
        },
        {
          "command": "hspace.renew",
          "when": "view == hspace.recent && viewItem == hspacePage",
          "group": "1_actions"
        },
        {
          "command": "hspace.setPassword",
          "when": "view == hspace.recent",
          "group": "1_actions"
        },
        {
          "command": "hspace.delete",
          "when": "view == hspace.recent",
          "group": "2_danger"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "hspace.recent",
          "name": "HSpace · Recent"
        }
      ]
    },
    "configuration": {
      "title": "HSpace",
      "properties": {
        "hspace.apiBaseUrl": {
          "type": "string",
          "default": "https://html-share.kzhan.workers.dev",
          "description": "Backend API base URL (no trailing slash)."
        },
        "hspace.defaultExpiryDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Default expiry in days for shared links (1–30). Links always expire; renew anytime before they lapse. Anonymous links are capped at 3 days and can't be renewed — sign in for up to 30 renewable days."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.0"
  }
}