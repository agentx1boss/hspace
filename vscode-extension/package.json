{
  "name": "hspace",
  "displayName": "HSpace",
  "description": "私密分享 AI 生成的内容：一键把 HTML 发布成链接+密码，只给该看的人。Private sharing for AI-generated content.",
  "version": "0.1.3",
  "publisher": "agentx1boss",
  "license": "MIT",
  "icon": "icon.png",
  "repository": { "type": "git", "url": "https://github.com/agentx1boss/hspace" },
  "bugs": { "url": "https://github.com/agentx1boss/hspace/issues" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["html", "share", "publish", "host", "ai"],
  "galleryBanner": { "color": "#1A1D24", "theme": "dark" },
  "activationEvents": ["onLanguage:html"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "hspace.publish", "title": "HSpace: 发布当前 HTML", "icon": "$(cloud-upload)" },
      { "command": "hspace.setApiKey", "title": "HSpace: 设置 API Key（登录）" },
      { "command": "hspace.signOut", "title": "HSpace: 退出登录（清除 API Key）" },
      { "command": "hspace.setPassword", "title": "HSpace: 设置/修改密码" },
      { "command": "hspace.copyLink", "title": "HSpace: 复制链接" },
      { "command": "hspace.openInBrowser", "title": "HSpace: 浏览器打开" },
      { "command": "hspace.delete", "title": "HSpace: 删除页面", "icon": "$(trash)" },
      { "command": "hspace.refresh", "title": "HSpace: 刷新列表", "icon": "$(refresh)" }
    ],
    "menus": {
      "editor/title": [
        { "command": "hspace.publish", "when": "resourceExtname == .html || resourceExtname == .htm", "group": "navigation" }
      ],
      "explorer/context": [
        { "command": "hspace.publish", "when": "resourceExtname == .html || resourceExtname == .htm", "group": "7_modification" }
      ],
      "view/title": [
        { "command": "hspace.refresh", "when": "view == hspace.recent", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "hspace.openInBrowser", "when": "view == hspace.recent", "group": "inline" },
        { "command": "hspace.copyLink", "when": "view == hspace.recent", "group": "1_actions" },
        { "command": "hspace.setPassword", "when": "view == hspace.recent", "group": "1_actions" },
        { "command": "hspace.delete", "when": "view == hspace.recent", "group": "2_danger" }
      ]
    },
    "views": {
      "explorer": [
        { "id": "hspace.recent", "name": "HSpace · 最近发布" }
      ]
    },
    "configuration": {
      "title": "HSpace",
      "properties": {
        "hspace.apiBaseUrl": {
          "type": "string",
          "default": "https://html-share.kzhan.workers.dev",
          "description": "后端 API 地址（不含末尾斜杠）。"
        },
        "hspace.defaultExpiryDays": {
          "type": "number",
          "default": 7,
          "description": "发布链接的默认过期天数（登录后可设 0 表示永不过期）。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.0"
  }
}
